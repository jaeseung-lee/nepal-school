NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY

# Optional analytics and ownership verification
# GA4 and PostHog load only after the visitor grants consent.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Use the public PostHog project token (phc_), never a personal API key (phx_).
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# US Cloud default. Set https://eu.i.posthog.com for an EU Cloud project.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Optional for automation tuning
YOLO_REQUEST_DELAY_MS=800
YOLO_DETAIL_DELAY_MS=1200
